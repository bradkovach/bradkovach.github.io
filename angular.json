{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"site": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "projects/bradkovach.github.io",
			"sourceRoot": "projects/bradkovach.github.io/src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular/build:application",
					"options": {
						"outputPath": "dist/bradkovach.github.io",
						"index": "projects/bradkovach.github.io/src/index.html",
						"browser": "projects/bradkovach.github.io/src/main.ts",
						"polyfills": ["zone.js"],
						"tsConfig": "projects/bradkovach.github.io/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/bradkovach.github.io/src/favicon.ico",
							"projects/bradkovach.github.io/src/assets"
						],
						"styles": [
							"projects/bradkovach.github.io/src/styles.scss",
							"node_modules/bootstrap/dist/css/bootstrap.min.css",
							"node_modules/highlight.js/styles/github.css"
						],
						"scripts": [],
						"server": "projects/bradkovach.github.io/src/main.server.ts",

						"allowedCommonJsDependencies": [
							"markdown-it-replace-link",
							"front-matter"
						],
						"namedChunks": true
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "3mb",
									"maximumError": "4mb"
								}
							],
							"outputHashing": "all"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular/build:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "site:build:production"
						},
						"development": {
							"buildTarget": "site:build:development"
						}
					},
					"defaultConfiguration": "development"
				},
				"extract-i18n": {
					"builder": "@angular/build:extract-i18n",
					"options": {
						"buildTarget": "site:build"
					}
				},
				"test": {
					"builder": "@angular/build:karma",
					"options": {
						"polyfills": ["zone.js", "zone.js/testing"],
						"tsConfig": "projects/bradkovach.github.io/tsconfig.spec.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/bradkovach.github.io/src/favicon.ico",
							"projects/bradkovach.github.io/src/assets"
						],
						"styles": [
							"projects/bradkovach.github.io/src/styles.scss"
						],
						"scripts": []
					}
				},
				"lint": {
					"builder": "@angular-eslint/builder:lint",
					"options": {
						"lintFilePatterns": [
							"projects/bradkovach.github.io/**/*.ts",
							"projects/bradkovach.github.io/**/*.html"
						],
						"eslintConfig": "projects/bradkovach.github.io/eslint.config.js"
					}
				}
			}
		},
		"choice-gas": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "projects/choice-gas",
			"sourceRoot": "projects/choice-gas/src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular/build:application",
					"options": {
						"browser": "projects/choice-gas/src/main.ts",
						"tsConfig": "projects/choice-gas/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							{
								"glob": "**/*",
								"input": "projects/choice-gas/public"
							}
						],
						"styles": [
							"projects/choice-gas/src/styles.scss",

							"node_modules/bootstrap/dist/css/bootstrap.min.css",
							"node_modules/highlight.js/styles/github.css"
						],
						"server": "projects/choice-gas/src/main.server.ts",
						"outputMode": "server",
						"security": {
							"allowedHosts": []
						},
						"ssr": {
							"entry": "projects/choice-gas/src/server.ts"
						}
					},
					"configurations": {
						"production": {
							"prerender": {
								"routesFile": "projects/choice-gas/routes.txt"
							},
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "500kB",
									"maximumError": "1MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "4kB",
									"maximumError": "8kB"
								}
							],
							"outputHashing": "all"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular/build:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "choice-gas:build:production"
						},
						"development": {
							"buildTarget": "choice-gas:build:development"
						}
					},
					"defaultConfiguration": "development"
				},
				"test": {
					"builder": "@angular/build:unit-test"
				}
			}
		}
	},

	"schematics": {
		"@schematics/angular:component": {
			"type": "component"
		},
		"@schematics/angular:directive": {
			"type": "directive"
		},
		"@schematics/angular:service": {
			"type": "service"
		},
		"@schematics/angular:guard": {
			"typeSeparator": "."
		},
		"@schematics/angular:interceptor": {
			"typeSeparator": "."
		},
		"@schematics/angular:module": {
			"typeSeparator": "."
		},
		"@schematics/angular:pipe": {
			"typeSeparator": "."
		},
		"@schematics/angular:resolver": {
			"typeSeparator": "."
		}
	}
}
